<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <requires lib="gtk+" version="3.20" />

  <object class="GtkWindow" id="main_window">
    <!-- Window size -->
    <property name="default-width">1200</property>
    <property name="default-height">700</property>
    <!-- Title -->
    <property name="title">OCR</property>

    <!-- Wrapper -->
    <child>
      <object class="GtkBox">
        <property name="orientation">vertical</property>

        <!-- Toolbar -->
        <child>
          <object class="GtkHeaderBar">

            <!-- Import image button -->
            <child>
              <object class="GtkButton" id="open_button">
                <property name="label">Open Image</property>
              </object>
            </child>

            <!-- Run OCR on selected image button -->
            <child>
              <object class="GtkButton" id="ocr_button">
                <property name="label">Run OCR</property>
                <property name="sensitive">False</property>
              </object>
            </child>

            <!-- Save extracted text button -->
            <child>
              <object class="GtkButton" id="save_button">
                <property name="label">Save Text</property>
                <property name="sensitive">False</property>
              </object>
            </child>

            <!-- Quit button -->
            <child>
              <object class="GtkButton" id="quit_button">
                <property name="label">Quit</property>
              </object>
            </child>

          </object>
        </child>

        <!-- Spinner -->
        <child>
          <object class="GtkBox">
            <property name="orientation">horizontal</property>
            <property name="spacing">6</property>

            <child>
              <object class="GtkSpinner" id="spinner">
                <property name="visible">True</property>
              </object>
            </child>

          </object>
        </child>

        <!-- Main Area -->
        <child>
          <object class="GtkPaned">

            <!-- LEFT: display selected image -->
            <child>
              <object class="GtkScrolledWindow">
                <!-- Adaptative size -->
                <property name="hexpand">True</property>
                <property name="vexpand">True</property>

                <!-- Image placeholder -->
                <child>
                  <object class="GtkImage" id="image_preview" />
                </child>

              </object>
            </child>

            <!-- RIGHT: display extracted text -->
            <child>
              <object class="GtkTextView" id="text_view">
                <property name="wrap-mode">word-char</property>
                <property name="monospace">True</property>
              </object>
            </child>

          </object>
        </child>

        <!-- Status Bar -->
        <child>
          <object class="GtkLabel" id="status_label">
            <property name="label">Ready</property>
            <property name="margin">8</property>
          </object>
        </child>

      </object>
    </child>
  </object>
</interface>